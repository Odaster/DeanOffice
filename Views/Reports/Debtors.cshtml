@model IEnumerable<ReportDebtorViewModel>

@{
    ViewData["Title"] = "Задолженности";
}

<div class="d-print-none d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Студенты с задолженностями</h1>
    <div>
        <button class="btn btn-outline-secondary" onclick="window.print()">Печать</button>
        <a class="btn btn-outline-success" asp-action="ExportDebtors" asp-route-format="csv">CSV</a>
        <a class="btn btn-outline-success" asp-action="ExportDebtors" asp-route-format="xls">Excel</a>
        <a class="btn btn-outline-success" asp-action="ExportDebtors" asp-route-format="doc">Word</a>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead><tr><th>Студент</th><th>Группа</th><th>Дисциплина</th><th>Оценка</th></tr></thead>
    <tbody>
    @foreach (var row in Model)
    {
        <tr><td>@row.StudentName</td><td>@row.GroupName</td><td>@row.SubjectName</td><td>@row.GradeValue</td></tr>
    }
    </tbody>
</table>
