@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Новый пароль";
}

<h1 class="h3 mb-3">Новый пароль</h1>

<div class="row">
    <div class="col-md-5">
        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Token" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="NewPassword" class="form-control" />
                    <button class="btn btn-outline-secondary toggle-password" type="button" data-target="NewPassword" aria-label="Показать или скрыть новый пароль">&#128065;</button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <button class="btn btn-outline-secondary toggle-password" type="button" data-target="ConfirmPassword" aria-label="Показать или скрыть подтверждение пароля">&#128065;</button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <button class="btn btn-primary" type="submit">Сохранить новый пароль</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.toggle-password').forEach(function (button) {
            button.addEventListener('click', function () {
                var input = document.getElementById(button.dataset.target);
                if (!input) {
                    return;
                }

                input.type = input.type === 'password' ? 'text' : 'password';
            });
        });
    </script>
}
