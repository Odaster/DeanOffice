@model IEnumerable<StatementRequest>

@{
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = isAdmin ? "Ведомости" : "Мои ведомости";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    @if (User.IsInRole("Student"))
    {
        <a class="btn btn-primary" asp-action="Create">Заказать ведомостичку</a>
    }
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Дата</th>
            @if (isAdmin)
            {
                <th>Студент</th>
                <th>Группа</th>
            }
            <th>Тип</th>
            <th>Данные заявки</th>
            <th>Статус</th>
            <th>Комментарий</th>
            @if (isAdmin)
            {
                <th class="text-end">Действия</th>
            }
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            @if (isAdmin)
            {
                <td>@item.Student?.FullName</td>
                <td>@item.Student?.Group?.Name</td>
            }
            <td>@item.RequestType</td>
            <td>
                @if (item.RequestType == StatementRequest.TypeEducationCertificate)
                {
                    <div>Герб: @(item.CertificateWithEmblem ? "да" : "нет")</div>
                    <div>Назначение: @item.CertificatePurpose</div>
                }
                else
                {
                    <div>Предмет: @item.Subject?.Name</div>
                    <div>Преподаватель: @item.Teacher?.FullName</div>
                    <div>Дата пропуска: @item.MissedDate?.ToString("dd.MM.yyyy")</div>
                    <div>Причина: @item.AbsenceReason</div>
                }
            </td>
            <td>
                <span class="badge @(item.Status == StatementRequest.StatusRejected ? "bg-danger" : item.Status == StatementRequest.StatusPrinted ? "bg-success" : "bg-secondary")">
                    @item.Status
                </span>
            </td>
            <td>@item.AdminComment</td>
            @if (isAdmin)
            {
                <td class="text-end table-actions">
                    <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                    <span>|</span>
                    <a asp-action="Print" asp-route-id="@item.Id">Печать</a>
                    <span>|</span>
                    <a asp-action="ExportWord" asp-route-id="@item.Id">Word</a>
                </td>
            }
        </tr>
    }
    </tbody>
</table>
