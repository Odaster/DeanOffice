@model Attendance

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="row">
    <div class="col-md-4 mb-3"><label asp-for="StudentId" class="form-label">Студент</label><select asp-for="StudentId" asp-items="ViewBag.StudentId" class="form-select"></select></div>
    <div class="col-md-4 mb-3"><label asp-for="GroupSubjectId" class="form-label">Дисциплина группы</label><select asp-for="GroupSubjectId" asp-items="ViewBag.GroupSubjectId" class="form-select"></select></div>
    <div class="col-md-4 mb-3"><label asp-for="LessonDate" class="form-label">Дата занятия</label><input asp-for="LessonDate" class="form-control" type="date" /></div>
    <div class="col-md-12 mb-3"><label asp-for="Comment" class="form-label">Комментарий</label><input asp-for="Comment" class="form-control" /></div>
</div>
<div class="form-check mb-3">
    <input asp-for="IsPresent" class="form-check-input" />
    <label asp-for="IsPresent" class="form-check-label">Присутствовал</label>
</div>
