@model IEnumerable<Attendance>

@{
    ViewData["Title"] = "Посещаемость";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 mb-0">Посещаемость</h1>
    <div class="d-flex flex-wrap gap-2">
        @if (User.IsInRole("Student"))
        {
            <a class="btn btn-primary" asp-controller="StatementRequests" asp-action="Create">Заказать ведомостичку</a>
            <a class="btn btn-outline-secondary" asp-controller="StatementRequests" asp-action="Index">Статус ведомостичек</a>
        }
        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <a class="btn btn-primary" asp-action="Create">Добавить</a>
        }
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead><tr><th>Дата</th><th>Студент</th><th>Группа</th><th>Дисциплина</th><th>Присутствовал</th><th>Комментарий</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.LessonDate.ToShortDateString()</td>
            <td>@item.Student?.FullName</td>
            <td>@item.Student?.Group?.Name</td>
            <td>@item.GroupSubject?.Subject?.Name</td>
            <td>@(item.IsPresent ? "Да" : "Нет")</td>
            <td>@item.Comment</td>
            <td>
                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
