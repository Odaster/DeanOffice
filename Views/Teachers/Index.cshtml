@model IEnumerable<Teacher>

@{
    ViewData["Title"] = "Преподаватели";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Преподаватели</h1>
    @if (User.IsInRole("Admin"))
    {
        <a class="btn btn-primary" asp-action="Create">Добавить</a>
    }
</div>

<table class="table table-striped table-bordered">
    <thead><tr><th>ФИО</th><th>Кафедра</th><th>Email</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FullName</td>
            <td>@item.Department</td>
            <td>@item.Email</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Детали</a>
                @if (User.IsInRole("Admin"))
                {
                    <span> | </span><a asp-action="Edit" asp-route-id="@item.Id">Изменить</a><span> | </span><a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
