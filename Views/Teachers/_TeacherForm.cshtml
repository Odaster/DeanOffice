@model Teacher

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="row">
    <div class="col-md-4 mb-3"><label asp-for="LastName" class="form-label">Фамилия</label><input asp-for="LastName" class="form-control" /></div>
    <div class="col-md-4 mb-3"><label asp-for="FirstName" class="form-label">Имя</label><input asp-for="FirstName" class="form-control" /></div>
    <div class="col-md-4 mb-3"><label asp-for="MiddleName" class="form-label">Отчество</label><input asp-for="MiddleName" class="form-control" /></div>
    <div class="col-md-6 mb-3"><label asp-for="Department" class="form-label">Кафедра</label><input asp-for="Department" class="form-control" /></div>
    <div class="col-md-6 mb-3"><label asp-for="Email" class="form-label">Email</label><input asp-for="Email" class="form-control" /></div>
</div>
